<Project>
  <ItemDefinitionGroup>
    <ClCompile>
      <!-- Mark GSL as an external include path so /external:W0 applies to it,
           silencing C4067 which newer MSVC versions emit from GSL headers -->
      <AdditionalOptions>%(AdditionalOptions) /external:I$(MSBuildThisFileDirectory)deps/GSL/include /wd4067</AdditionalOptions>
    </ClCompile>
  </ItemDefinitionGroup>
</Project>
